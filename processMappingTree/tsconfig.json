{
    "compilerOptions": {
        "target": "ES6",
        "lib": ["ES6", "dom"],
        "moduleResolution": "node",
        "module": "commonjs",
        "outDir": ".tmp/build",
        "rootDir": ".",
        "strict": true,
        "noImplicitAny": true,
        "noImplicitThis": true,
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "noImplicitReturns": true,
        "skipLibCheck": true,
        "esModuleInterop": true
    },
    "include": ["src/**/*.ts", "test/**/*.ts"],
    "exclude": ["node_modules", ".tmp"]
}
