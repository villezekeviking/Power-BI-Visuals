{
    "name": "processmappingtree",
    "description": "Process Mapping Tree – Visualize event-driven process flows with step counts and avg-time-between-steps metrics",
    "version": "1.0.0",
    "scripts": {
        "pbiviz": "pbiviz",
        "start": "pbiviz start",
        "build": "pbiviz package",
        "package": "pbiviz package",
        "test": "jest --coverage"
    },
    "dependencies": {
        "powerbi-visuals-api": "~5.3.0"
    },
    "devDependencies": {
        "@types/jest": "^29.5.12",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^30.3.0",
        "powerbi-visuals-tools": "^5.4.2",
        "ts-jest": "^29.1.4",
        "typescript": "~5.3.3"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "jest-environment-jsdom",
        "testMatch": ["**/test/**/*.test.ts"],
        "transform": {
            "^.+\\.tsx?$": ["ts-jest", { "tsconfig": "tsconfig.json" }]
        }
    }
}
